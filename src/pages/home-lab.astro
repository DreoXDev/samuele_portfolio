---
import BaseLayout from '../layouts/BaseLayout.astro'
import SiteShell from '../components/layout/SiteShell.astro'
import HomeLabHero from '../components/homelab/HomeLabHero.astro'
import HomeLabArchitecture from '../components/homelab/HomeLabArchitecture.vue'
import HomeLabServices from '../components/homelab/HomeLabServices.astro'
import Button from '../components/common/Button.astro'
import Container from '../components/common/Container.astro'
---

<BaseLayout
  title="Samuele Poretti - Personal Home Lab"
  description="A personal home lab project by Samuele Poretti, focused on Docker, reverse proxy routing, secure tunnels, monitoring and self-hosted services."
>
  <SiteShell>
    <HomeLabHero />

    <HomeLabArchitecture client:load />

    <HomeLabServices />

    <section class="py-16 bg-background-dark/80 text-center border-t border-border-dark/30">
      <Container>
        <p class="text-xs text-text-muted font-mono mb-4">// End of Infrastructure Case Study</p>
        <Button href="/" variant="outline">
          Return to Portfolio
        </Button>
      </Container>
    </section>
  </SiteShell>
</BaseLayout>

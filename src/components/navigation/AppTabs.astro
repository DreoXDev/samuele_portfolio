---
interface Props {
  active: 'home' | 'projects' | 'timeline' | 'home_lab' | 'contact'
  boot?: boolean
}

const { active, boot = false } = Astro.props

const tabs = [
  { key: 'home', label: '_home', href: '#home', target: 'home' },
  { key: 'projects', label: '_projects', href: '#projects', target: 'projects' },
  { key: 'timeline', label: '_timeline', href: '#timeline', target: 'timeline' },
  { key: 'home_lab', label: '_home_lab', href: '/home-lab' },
  { key: 'contact', label: '_contact', href: '#contact', target: 'contact' },
]
---

<nav aria-label="Portfolio sections" class="app-tabs">
  {tabs.map((tab) => (
    <a
      href={tab.href}
      class:list={['app-tab', active === tab.key && 'app-tab-active']}
      aria-current={active === tab.key ? 'page' : undefined}
      data-boot={boot ? 'tab' : undefined}
      data-nav-target={tab.target}
    >
      {tab.label}
    </a>
  ))}
</nav>

<style>
  .app-tabs {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .app-tabs::-webkit-scrollbar {
    display: none;
  }

  .app-tab {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0 0.75rem;
    border: 1px solid transparent;
    border-radius: 0.45rem 0.45rem 0.2rem 0.2rem;
    color: #9ca3af;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    background: rgba(255, 255, 255, 0.03);
    transition:
      color 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .app-tab:hover,
  .app-tab:focus-visible {
    color: #f4f4f5;
    border-color: rgba(255, 59, 59, 0.35);
    background: rgba(255, 59, 59, 0.09);
    box-shadow: 0 0 18px rgba(255, 59, 59, 0.12);
  }

  .app-tab-active {
    color: #ff6b6b;
    border-color: rgba(255, 59, 59, 0.4);
    background: rgba(255, 59, 59, 0.12);
  }

  @media (max-width: 760px) {
    .app-tabs {
      order: 2;
      width: 100%;
      padding-top: 0.55rem;
    }

    .app-tab {
      min-height: 1.9rem;
      padding: 0 0.65rem;
      font-size: 0.68rem;
    }
  }
</style>

---
import Container from '../common/Container.astro'
---
<section class="py-20 border-b border-border-dark/30 bg-background-dark relative overflow-hidden">
  <!-- Subtle radial gradient highlight -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(239,68,68,0.08),rgba(255,255,255,0))]"></div>
  <Container class="relative z-10 text-center max-w-3xl">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 border border-red-primary/30 rounded-full text-xs font-mono text-red-primary bg-red-primary/5 mb-6 select-none">
      <span class="w-1.5 h-1.5 rounded-full bg-red-primary animate-pulse"></span>
      <span>Infrastructure Online</span>
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-text-main font-mono mb-6">
      Personal Home Lab
    </h1>
    <p class="text-base sm:text-lg text-text-muted leading-relaxed mb-4">
      A small Linux server where I experiment with Docker, reverse proxy routing, secure tunnels, monitoring, and self-hosted services.
    </p>
    <p class="text-xs text-text-subtle font-mono">
      The same infrastructure is planned to host this portfolio through a custom domain.
    </p>
  </Container>
</section>

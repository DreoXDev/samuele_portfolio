---
import Card from '../common/Card.astro'
---
<section class="py-16 bg-background-dark">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="mb-12 text-center">
      <h2 class="text-xl sm:text-2xl font-bold tracking-tight text-text-main font-mono mb-2">
        Live Node Resource Monitor
      </h2>
      <p class="text-sm text-text-muted">
        Mock telemetry data representing current resource allocation on the server.
      </p>
    </div>

    <!-- Monitor Panel -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      
      <!-- CPU Monitor -->
      <Card class="border-border-dark/60 bg-surface-dark/40">
        <div class="text-[10px] font-mono text-text-subtle uppercase mb-1">// Telemetry</div>
        <h3 class="text-sm font-bold text-text-main font-mono mb-4">CPU Load</h3>
        <div class="flex items-end justify-between mb-1">
          <span class="text-2xl font-bold font-mono text-text-main">18.4%</span>
          <span class="text-xs font-mono text-text-muted">Intel Celeron J4125</span>
        </div>
        <div class="w-full bg-surface-soft h-2 rounded overflow-hidden">
          <div class="bg-red-primary h-full rounded" style="width: 18.4%"></div>
        </div>
        <div class="flex justify-between text-[10px] text-text-subtle font-mono mt-2">
          <span>4 cores</span>
          <span>2.00 GHz</span>
        </div>
      </Card>

      <!-- RAM Monitor -->
      <Card class="border-border-dark/60 bg-surface-dark/40">
        <div class="text-[10px] font-mono text-text-subtle uppercase mb-1">// Telemetry</div>
        <h3 class="text-sm font-bold text-text-main font-mono mb-4">Memory Usage</h3>
        <div class="flex items-end justify-between mb-1">
          <span class="text-2xl font-bold font-mono text-text-main">2.1 GB</span>
          <span class="text-xs font-mono text-text-muted">/ 8.0 GB (26%)</span>
        </div>
        <div class="w-full bg-surface-soft h-2 rounded overflow-hidden">
          <div class="bg-red-primary h-full rounded" style="width: 26%"></div>
        </div>
        <div class="flex justify-between text-[10px] text-text-subtle font-mono mt-2">
          <span>DDR4 Non-ECC</span>
          <span>Active: 24 containers</span>
        </div>
      </Card>

      <!-- Storage Monitor -->
      <Card class="border-border-dark/60 bg-surface-dark/40">
        <div class="text-[10px] font-mono text-text-subtle uppercase mb-1">// Telemetry</div>
        <h3 class="text-sm font-bold text-text-main font-mono mb-4">Disk Capacity</h3>
        <div class="flex items-end justify-between mb-1">
          <span class="text-2xl font-bold font-mono text-text-main">1.2 TB</span>
          <span class="text-xs font-mono text-text-muted">/ 4.0 TB (30%)</span>
        </div>
        <div class="w-full bg-surface-soft h-2 rounded overflow-hidden">
          <div class="bg-red-primary h-full rounded" style="width: 30%"></div>
        </div>
        <div class="flex justify-between text-[10px] text-text-subtle font-mono mt-2">
          <span>RAID 1 Mirror</span>
          <span>Ext4 Filesystem</span>
        </div>
      </Card>

    </div>

    <!-- Security Notice -->
    <div class="border border-amber-500/20 bg-amber-500/5 rounded-lg p-5 max-w-3xl mx-auto flex gap-4 items-start">
      <div class="p-2 bg-amber-500/10 text-amber-500 rounded font-mono font-bold text-sm">!</div>
      <div class="space-y-1">
        <h4 class="text-sm font-bold text-text-main font-mono">Security Isolation Warning</h4>
        <p class="text-xs text-text-muted leading-relaxed">
          This page intentionally avoids exposing sensitive infrastructure details such as external IP addresses, private file directory paths, system credentials, API tokens, or complete firewall rulesets.
        </p>
      </div>
    </div>

  </div>
</section>

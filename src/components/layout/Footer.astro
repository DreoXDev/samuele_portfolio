---
import { siteConfig } from '../../data/site'
const currentYear = new Date().getFullYear()
---
<footer class="border-t border-border-dark/60 bg-background-dark/80 py-8 text-center text-xs text-text-subtle mt-auto">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <div>
        <p>© {currentYear} {siteConfig.author}. All rights reserved.</p>
      </div>
      <div class="flex gap-4">
        <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="hover:text-red-primary transition-colors duration-200">GitHub</a>
        <a href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-red-primary transition-colors duration-200">LinkedIn</a>
        <a href={`mailto:${siteConfig.email}`} class="hover:text-red-primary transition-colors duration-200">Email</a>
      </div>
      <div>
        <span class="inline-flex items-center gap-1.5 font-mono text-[10px] text-text-subtle border border-border-dark px-2 py-0.5 rounded bg-surface-dark/50">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
          sys status: normal
        </span>
      </div>
    </div>
  </div>
</footer>

---
interface Props {
  num: string
  text: string
  class?: string
}

const { num, text, class: className = '' } = Astro.props
---
<div class={`flex items-center gap-2 text-xs font-mono font-bold tracking-wider text-red-primary select-none ${className}`}>
  <span>[</span>
  <span class="text-red-primary">{num}</span>
  <span class="text-text-subtle">.</span>
  <span class="text-text-main uppercase">{text}</span>
  <span>]</span>
  <div class="h-[1px] flex-grow bg-border-dark/60 ml-2"></div>
</div>

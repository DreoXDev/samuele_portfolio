---
interface Props {
  title: string
  class?: string
}

const { title, class: className = '' } = Astro.props
---
<div class={`flex flex-col border border-border-dark/60 bg-surface-dark/90 rounded-lg overflow-hidden shadow-lg ${className}`}>
  <!-- Window Header -->
  <div class="flex items-center justify-between px-4 py-2.5 border-b border-border-dark/60 bg-surface-dark/50 select-none">
    <div class="flex items-center gap-2">
      <div class="w-3 h-3 rounded-full bg-red-500/70 border border-red-600/30"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500/70 border border-yellow-600/30"></div>
      <div class="w-3 h-3 rounded-full bg-green-500/70 border border-green-600/30"></div>
    </div>
    <div class="text-xs text-text-muted font-mono truncate px-4">{title}</div>
    <div class="w-12"></div>
  </div>
  <!-- Window Content -->
  <div class="flex-grow p-4 md:p-6 overflow-auto">
    <slot />
  </div>
</div>

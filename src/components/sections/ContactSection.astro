---
import { siteConfig } from '../../data/site'
import Card from '../common/Card.astro'
import Button from '../common/Button.astro'
---
<section id="contact" class="scroll-section py-20 bg-background-dark border-b border-border-dark/30">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="mb-12 text-center">
      <div class="inline-flex items-center gap-2 text-xs font-mono font-bold tracking-wider text-red-primary select-none mb-3">
        <span>[</span>
        <span class="text-red-primary">03</span>
        <span class="text-text-subtle">.</span>
        <span class="text-text-main uppercase">Contact</span>
        <span>]</span>
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-text-main font-mono mt-2">
        ~/get_in_touch
      </h2>
      <p class="text-sm text-text-muted mt-2">
        Let's work together. I am currently open to internships, collaborations, and junior developer positions.
      </p>
    </div>

    <!-- Contact Panel Mockup -->
    <Card hoverable={true} class="max-w-2xl mx-auto shadow-xl">
      <!-- Terminal Header -->
      <div class="flex items-center justify-between border-b border-border-dark/60 pb-3 mb-4 select-none">
        <div class="text-xs font-mono text-red-primary">HTTP/1.1 200 OK</div>
        <div class="text-[10px] font-mono text-text-subtle">content-type: application/json</div>
      </div>

      <!-- JSON content -->
      <div class="font-mono text-xs sm:text-sm text-text-muted leading-relaxed mb-6 overflow-x-auto whitespace-pre">
<span class="text-purple-400">{</span>
  <span class="text-emerald-400">"status"</span>: <span class="text-amber-500">"available"</span>,
  <span class="text-emerald-400">"location"</span>: <span class="text-amber-500">"{siteConfig.location}"</span>,
  <span class="text-emerald-400">"email"</span>: <span class="text-amber-500">"{siteConfig.email}"</span>,
  <span class="text-emerald-400">"links"</span>: <span class="text-purple-400">[</span>
    <span class="text-amber-500">"<a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="hover:underline hover:text-red-primary">{siteConfig.github}</a>"</span>,
    <span class="text-amber-500">"<a href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer" class="hover:underline hover:text-red-primary">{siteConfig.linkedin}</a>"</span>
  <span class="text-purple-400">]</span>,
  <span class="text-emerald-400">"opportunities"</span>: <span class="text-purple-400">[</span>
    <span class="text-amber-500">"Internships"</span>,
    <span class="text-amber-500">"Junior Developer Positions"</span>,
    <span class="text-amber-500">"Open Source Collaborations"</span>
  <span class="text-purple-400">]</span>
<span class="text-purple-400">}</span></div>

      <!-- Action CTAs -->
      <div class="flex flex-wrap gap-4 justify-center sm:justify-start">
        <Button href={`mailto:${siteConfig.email}`} variant="primary" class="w-full sm:w-auto">
          Send Email
        </Button>
        <Button href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer" variant="outline" class="w-full sm:w-auto">
          LinkedIn Profile
        </Button>
        <Button href={siteConfig.cvPath} target="_blank" variant="secondary" class="w-full sm:w-auto">
          Download CV
        </Button>
      </div>
    </Card>

  </div>
</section>
